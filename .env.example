# =========================
# ksrpc docker-limited 环境变量模板（最小版）
# 文件固定为：.env/.env.example/docker-compose.yml/ksrpc.conf.py/gunicorn.conf.py/tushare_limited.py/Dockerfile
# =========================

# [可选] 容器名称
KSRPC_CONTAINER_NAME=ksrpc

# [可选] 主机映射端口
KSRPC_HOST_PORT=19801

# =========================
# 运行参数
# =========================

# [可选] Gunicorn 参数
KSRPC_GUNICORN_WORKER_CLASS=aiohttp.GunicornWebWorker
KSRPC_GUNICORN_WORKERS=2
GUNICORN_CMD_ARGS="--reuse-port --worker-tmp-dir=/dev/shm"
KSRPC_GUNICORN_BACKLOG=1024
KSRPC_GUNICORN_TIMEOUT=8
KSRPC_GUNICORN_GRACEFUL_TIMEOUT=15
KSRPC_GUNICORN_MAX_REQUESTS=0
KSRPC_GUNICORN_MAX_REQUESTS_JITTER=0
KSRPC_GUNICORN_KEEPALIVE=2

# [必填] ksrpc.server.tushare 使用的 Tushare Token（请替换为真实令牌）
TUSHARE_TOKEN=replace_with_real_tushare_token
# [可选，默认 30] ksrpc 服务端调用 tushare 的单次超时（单位：秒，支持小数）
TUSHARE_TIMEOUT=30

# [必填] 基础认证凭据 JSON（标准键名）
# 示例：{"admin":"strong_password","viewer":"readonly_password"}
USER_CREDENTIALS={"admin":"change_me_now"}

# [可选，默认 30] 请求时间戳校验窗口（单位：秒）
# 0: 关闭校验 | >0: 允许的最大时间差（秒）
TIMESTAMP_CHECK=30

# [可选但强烈推荐] 导入规则 JSON（安全边界）
# docker-limited 建议默认值：仅暴露白名单模块 tushare_limited（只提供 opt_mins）
# 客户端模块名：RpcClient("tushare_limited", conn, ...)
IMPORT_RULES={"tushare_limited":true,"ksrpc.server.tushare":false,"ksrpc.server.demo":false,"tushare":false,"ksrpc.server.*":false,"builtins":false,"*":false}

# [可选] 文件缓存开关与路径
# 实盘接口不要缓存
CACHE_ENABLE=false

# [可选] 缓存 TTL 路由（单位：秒）
# 示例：
# - 日线数据缓存 30 秒
# - 其他 tushare API 缓存 60 秒
# - 兜底缓存 600 秒
CACHE_TIMEOUT={"ksrpc.server.tushare.daily":30,"ksrpc.server.tushare.*":60,"*":600}
