# =========================
# ksrpc Docker 环境变量模板
# - 业务配置维护在根目录 config_server.py
# - gunicorn 进程参数维护在根目录 gunicorn.conf.py
# - .env 仅保留编排层参数和密钥
# =========================

# [必填] Docker Compose 使用的镜像引用
OCI_IMAGE_REF=www.yourdomain.com/ksrpc:edge

# [必填] 容器名称
KSRPC_CONTAINER_NAME=ksrpc-dev

# [必填] 主机暴露的服务端口
KSRPC_HOST_PORT=19801

# [可选] 多实例数量（./ksrpc-compose.sh）
KSRPC_INSTANCES=1

# [必填] ksrpc.server.tushare 使用的 Tushare Token（请替换为真实令牌）
TUSHARE_TOKEN=replace_with_real_tushare_token
