# =========================
# ksrpc Docker 环境变量模板
# =========================

# =========================
# docker 编排层
# =========================

# [必填] Docker Compose 使用的镜像引用
OCI_IMAGE_REF=www.yourdomain.com/ksrpc:edge

# [必填] 容器名称
KSRPC_CONTAINER_NAME=ksrpc
# [固定] docker-compose.yml 中重启策略为 restart: always

# [必填] 主机暴露的服务端口
# - 单实例 docker-compose.yml 使用此端口
# - 多实例脚本也以此作为起始端口，若端口占用会自动 +1 继续分配
KSRPC_HOST_PORT=19901

# [可选] 多实例数量（./ksrpc-compose.sh）
# =1 时退化为单实例 docker-compose.yml；>1 时自动生成 ksrpc-01, ksrpc-02 ...
KSRPC_INSTANCES=8

# Gunicorn 配置文件宿主机路径（文件路径语义）
KSRPC_GUNICORN_CONFIG_PATH=./gunicorn.conf.py

# ksrpc 配置文件宿主机路径（会挂载到容器 /etc/ksrpc/ksrpc.conf.py）
KSRPC_CONFIG_PATH=./ksrpc.conf.py

# =========================
# 手工维护区（服务标准键 + 运行参数）
# - 服务端配置使用标准键名
# - Gunicorn 变量保持 KSRPC_GUNICORN_*（gunicorn.conf.py 读取）
# =========================

# [可选] Gunicorn 参数
KSRPC_GUNICORN_WORKER_CLASS=aiohttp.GunicornWebWorker
KSRPC_GUNICORN_WORKERS=2
GUNICORN_CMD_ARGS="--reuse-port --worker-tmp-dir=/dev/shm"
KSRPC_GUNICORN_BACKLOG=1024
KSRPC_GUNICORN_TIMEOUT=8
KSRPC_GUNICORN_GRACEFUL_TIMEOUT=15
KSRPC_GUNICORN_MAX_REQUESTS=0
KSRPC_GUNICORN_MAX_REQUESTS_JITTER=0
KSRPC_GUNICORN_KEEPALIVE=2

# [可选，默认 8080] 服务监听端口（标准键）
PORT=8080
# HOST/PATH 均与系统环境变量同名，默认值由 ksrpc.conf.py 提供
# HOST 默认 None；PATH 默认 /api/v1

# [必填] ksrpc.server.tushare 使用的 Tushare Token（请替换为真实令牌）
TUSHARE_TOKEN=replace_with_real_tushare_token
# [可选，默认 30] ksrpc 服务端调用 tushare 的单次超时（单位：秒，支持小数）
# 3秒内含重试场景建议 1.2~1.5
TUSHARE_TIMEOUT=5

# [必填] 基础认证凭据 JSON（标准键名）
# 示例：{"admin":"strong_password","viewer":"readonly_password"}
USER_CREDENTIALS={"admin":"change_me_now"}

# [可选，默认 30] 请求时间戳校验窗口（单位：秒）
# 0: 关闭校验 | >0: 允许的最大时间差（秒）
TIMESTAMP_CHECK=30

# [可选但强烈推荐] 导入规则 JSON（安全边界）
# 生产环境建议默认值：仅暴露 tushare 代理
IMPORT_RULES={"ksrpc.server.tushare":true,"ksrpc.server.demo":false,"tushare":false,"ksrpc.server.*":false,"builtins":false,"*":false}

# [可选] 文件缓存开关与路径
# 实盘接口不要缓存
CACHE_ENABLE=false
# CACHE_PATH 由 docker-compose.yml 固定注入为 /opt/ksrpc/cache
# docker 挂载路径（编排层）
KSRPC_CACHE_HOST_PATH=./data/cache

# [可选] 缓存 TTL 路由（单位：秒）
# 示例：
# - 日线数据缓存 30 秒
# - 其他 tushare API 缓存 60 秒
# - 兜底缓存 600 秒
CACHE_TIMEOUT={"ksrpc.server.tushare.daily":30,"ksrpc.server.tushare.*":60,"*":600}
