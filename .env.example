# =========================
# ksrpc Docker 环境变量模板
# =========================

# [必填] Docker Compose 使用的镜像引用
OCI_IMAGE_REF=www.yourdomain.com/ksrpc:latest

# [必填] 容器名称
KSRPC_CONTAINER_NAME=ksrpc
# [固定] docker-compose.yml 中重启策略为 restart: always

# [必填] 主机暴露的服务端口
KSRPC_HOST_PORT=18080

# Gunicorn 配置文件宿主机路径（文件路径语义）
KSRPC_GUNICORN_CONFIG_PATH=./gunicorn.conf.py

# ksrpc 配置文件宿主机路径（会挂载到容器 /etc/ksrpc/ksrpc.conf.py）
KSRPC_CONFIG_PATH=./ksrpc.conf.py

# [可选] Gunicorn 传输效率关键参数（按“仅 WS 影响”从高到低，且保留 HTTP 关键项）
# Worker 模型（WS/HTTP 都关键）
KSRPC_GUNICORN_WORKER_CLASS=aiohttp.GunicornWebWorker
# Worker 数（并发核心）
KSRPC_GUNICORN_WORKERS=4
# 多 worker accept 竞争 + worker 心跳文件 I/O 抖动优化
GUNICORN_CMD_ARGS="--reuse-port --worker-tmp-dir=/dev/shm"
# 监听队列
KSRPC_GUNICORN_BACKLOG=2048
# 超时保护
KSRPC_GUNICORN_TIMEOUT=120
KSRPC_GUNICORN_GRACEFUL_TIMEOUT=30
# 平滑轮转
KSRPC_GUNICORN_MAX_REQUESTS=10000
KSRPC_GUNICORN_MAX_REQUESTS_JITTER=1000
# HTTP 连接复用
KSRPC_GUNICORN_KEEPALIVE=15

# [必填] API 根路径（服务端会在该路径下暴露 redirect/chunk/ws）
KSRPC_PATH=/api/v1

# [必填] ksrpc.server.tushare 使用的 Tushare Token（请替换为真实令牌）
TUSHARE_TOKEN=replace_with_real_tushare_token

# [必填] 基础认证（当 KSRPC_BASIC_CREDENTIALS_JSON 为空时生效）
KSRPC_BASIC_USER=admin
KSRPC_BASIC_PASSWORD=change_me_now

# [可选] 多用户凭据 JSON
# 若非空，将覆盖 KSRPC_BASIC_USER/KSRPC_BASIC_PASSWORD
# 示例：
# {"admin":"strong_password","viewer":"readonly_password"}
KSRPC_BASIC_CREDENTIALS_JSON=

# [可选但强烈推荐] 导入规则 JSON（安全边界）
# 生产环境建议默认值：仅暴露 tushare 代理
KSRPC_IMPORT_RULES_JSON={"ksrpc.server.tushare":true,"ksrpc.server.demo":false,"tushare":false,"ksrpc.server.*":false,"builtins":false,"*":false}

# [可选] 文件缓存开关与路径
# 实盘接口不要缓存
KSRPC_CACHE_ENABLE=false
KSRPC_CACHE_HOST_PATH=./data/cache

# [可选] 缓存 TTL 路由（单位：秒）
# 示例：
# - 日线数据缓存 30 秒
# - 其他 tushare API 缓存 60 秒
# - 兜底缓存 600 秒
KSRPC_CACHE_TIMEOUT_JSON={"ksrpc.server.tushare.daily":30,"ksrpc.server.tushare.*":60,"*":600}
